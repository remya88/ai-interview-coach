# ────────────────────────────────────────────────────────────────────────────
# AI Interview Coach – Environment Variables
# Copy this file to .env and fill in all values before starting the app.
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interview_coach

# JWT signing secret – change to a strong random string in production
JWT_SECRET=change-me-in-production

# OpenAI API key (required for AI coaching features)
OPENAI_API_KEY=

# Redis connection string
REDIS_URL=redis://localhost:6379

# Port the NestJS API listens on (default 3000)
PORT=3000
